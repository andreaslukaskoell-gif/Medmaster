{
  "name": "medmaster",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:seo": "vite build && node scripts/prerender.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "qa-kff": "npx tsx scripts/qa-kff.mts",
    "check": "npm run typecheck && npm run audit-bms && npm run qa-kff && npm run audit-security && npm run validate-vercel",
    "validate-vercel": "npx tsx scripts/validate-vercel.mts",
    "healthcheck": "npx tsx scripts/healthcheck-prod.mts",
    "check-payments": "npx tsx scripts/check-payments.mts",
    "test-webhook": "npx tsx scripts/test-webhook-e2e.mts",
    "audit-deps": "npm audit --production --audit-level=high",
    "audit-security": "npx tsx scripts/security-check.mts",
    "audit-bms": "npx tsx scripts/audit-bms-questions.mts",
    "audit-images": "npx tsx scripts/audit-bms-images.mts",
    "audit-stichworte-kapitel": "npx tsx scripts/audit-stichworte-kapitel.mts",
    "figurelabs-briefs": "npx tsx scripts/generate-figurelabs-briefs.mts",
    "seed-zahlenfolgen-1000": "npx tsx src/scripts/seedTaskDb.ts --generate kff-zahlenfolgen 1000",
    "generate-zahlenfolgen-pool": "npx tsx scripts/generate-zahlenfolgen-pool.mts --count 1000",
    "export-offizielle-angaben": "npx tsx scripts/export-offizielle-angaben.mts",
    "marketing": "npx tsx scripts/marketing-daily.mjs",
    "marketing:cards": "npx tsx scripts/generate-social-cards.mjs --all",
    "marketing:discord": "npx tsx scripts/post-discord-webhook.mjs",
    "marketing:discord-answer": "npx tsx scripts/post-discord-webhook.mjs --answer",
    "marketing:instagram": "npx tsx scripts/post-instagram.mjs",
    "marketing:instagram-dry": "npx tsx scripts/post-instagram.mjs --dry-run",
    "marketing:ig-token-check": "npx tsx scripts/refresh-ig-token.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "shipit": "echo 'Use git commands directly' && exit 1",
    "cap:sync": "npx cap sync",
    "cap:build": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:icons": "npx tsx scripts/generate-icons.mts",
    "cap:release": "npm run typecheck && npm run build && npx cap sync ios && echo '✅ Ready — open Xcode: npx cap open ios'"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@formkit/auto-animate": "^0.9.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/react": "^10.40.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cordova-plugin-purchase": "^13.13.1",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.34.1",
    "lucide-react": "^0.563.0",
    "mafs": "^0.21.0",
    "posthog-js": "^1.360.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "smiles-drawer": "^2.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.58.2",
    "prettier": "^3.4.2",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2",
    "vite-plugin-svgo": "^2.0.0",
    "vitest": "^4.1.4"
  }
}

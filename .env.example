VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: Sentry DSN for production error tracking (leave empty to disable)
# VITE_SENTRY_DSN=

# PostHog analytics (EU cloud recommended for GDPR)
# VITE_POSTHOG_KEY=phc_your_key_here
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Stripe Payment Link URL (create at dashboard.stripe.com/payment-links)
# VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link_here

# Admin email(s) for analytics dashboard access (comma-separated)
# VITE_ADMIN_EMAIL=luki@medmaster.at

# Meta Pixel / Facebook Pixel ID (for retargeting + conversion ads)
# VITE_META_PIXEL_ID=your_pixel_id_here

# Google Ads / GA4 Measurement ID (for search ads conversion tracking)
# VITE_GTAG_ID=AW-your_id_here
# Google Ads conversion labels (copy from Ads → Tools → Conversions → Tag setup)
# VITE_GTAG_CONV_SIGNUP=AbC1dEfGhIjKlMnO
# VITE_GTAG_CONV_CHECKOUT=XyZ2aBcDeFgHiJkL
